/target
# Cargo build output. The live-test crates are now members of the root
# workspace (single committed Cargo.lock), so there are no nested workspaces or
# per-workspace lockfiles to ignore.
target/
/db
/docs/cargo_docs/debug
/.helix
/live-tests/chain_cache/*
/live-tests/test_binaries/bins/*
/live-tests/target/*
!/live-tests/chain_cache/testnet_get_subtree_roots_sapling
!/live-tests/chain_cache/testnet_get_subtree_roots_orchard
.cargo
.local/
build/
.failed-tests
**/proptest-regressions/**
/result
